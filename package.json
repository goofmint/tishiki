{
  "name": "tishiki",
  "displayName": "Tishiki",
  "description": "Local Wiki engine for AI coding agents with built-in MCP server",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/goofmint/tishiki"
  },
  "publisher": "tishiki",
  "type": "commonjs",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension/extension.js",
  "bin": {
    "tishiki-mcp": "./dist/mcp/server.js"
  },
  "activationEvents": [
    "workspaceContains:docs/"
  ],
  "contributes": {
    "commands": [
      {
        "command": "tishiki.openPage",
        "title": "Tishiki: Open Wiki Page"
      },
      {
        "command": "tishiki.newPage",
        "title": "Tishiki: New Wiki Page"
      },
      {
        "command": "tishiki.deletePage",
        "title": "Tishiki: Delete Wiki Page"
      },
      {
        "command": "tishiki.previewPage",
        "title": "Tishiki: Preview Wiki Page"
      },
      {
        "command": "tishiki.refreshTree",
        "title": "Tishiki: Refresh Wiki Tree"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tishiki",
          "title": "Tishiki Wiki",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "tishiki": [
        {
          "id": "tishiki.wikiTree",
          "name": "Pages"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "tishiki.newPage",
          "when": "view == tishiki.wikiTree",
          "group": "navigation"
        },
        {
          "command": "tishiki.refreshTree",
          "when": "view == tishiki.wikiTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
